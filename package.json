{
  "private": true,
  "type": "module",
  "scripts": {
    "optimize:images": "imagemin ./src/images/*.* --out-dir ./src/images/optimized/",
    "start": "rm -rf build_local && npm run optimize:images && maizzle build local && maizzle serve",
    "build": "rm -rf build_production && npm run optimize:images && maizzle build production"
  },
  "dependencies": {
    "@maizzle/framework": "latest",
    "editions": "6.21.0",
    "tailwindcss": "^3.0.0",
    "tailwindcss-box-shadow": "^2.0.3",
    "tailwindcss-email-variants": "^3.0.1",
    "tailwindcss-mso": "^1.4.3",
    "tailwindcss-preset-email": "^1.1.0"
  },
  "devDependencies": {
    "imagemin-cli": "^8.0.0"
  }
}
